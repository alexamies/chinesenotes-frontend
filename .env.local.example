# Site theme — controls the primary colour used by the header, Find button,
# headword text, and textfield focus outline.
# Valid values: demo | chinesenotes | ntireader | hbreader
SITE_THEME=demo

# Session cookie signing — prevents forged session cookies.
# Generate with: openssl rand -hex 32
# Required in production; if unset, cookies are accepted without signature verification.
SESSION_SECRET=

# Google Cloud project ID — used by Firestore and reCAPTCHA Enterprise.
# On Cloud Run this is set automatically by the runtime; no entry needed in production.
# Locally: set this to your GCP project ID and run `gcloud auth application-default login`.
GOOGLE_CLOUD_PROJECT=

# GCS bucket holding chapter text files for the Library reader.
# Set to the bucket for the active site (e.g. my-chinesenotes-text, my-ntireader-text).
TEXT_BUCKET=

# Google reCAPTCHA Enterprise — enforced server-side after 25 interactions per day.
# Create a score-based site key at https://console.cloud.google.com/security/recaptcha
# The back end authenticates via ADC (service account on Cloud Run, or ADC locally).
# Leave unset to disable reCAPTCHA enforcement (interactions are still tracked in Firestore).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
