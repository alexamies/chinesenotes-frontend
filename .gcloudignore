/.pnp
.pnp.js

/coverage

/.next/
/out/
/build

.DS_Store
*.pem

npm-debug.log*
yarn-debug.log*
yarn-error.log*

.env*.local
.env

.vercel

*.tsbuildinfo
next-env.d.ts

chinesenotes-frontend.code-workspace
